---
import '../styles.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	heroImage?: string;
}

const { 
  title = "Therese Järvheden — Skådespelerska", 
  description = "Therese Järvheden — Swedish actress. Drama, comedy, voice. Featured in SVT's 'En våldsam kärlek', 'Karatefylla', Beck — 'Utan uppsåt'.",
  image = "https://a6c2528650.clvaw-cdnwnd.com/a1d4e2b76c0723db65512f7305fc0d9c/200000000-339e8339ea/Thess1114_lowres.jpg?ph=a6c2528650",
  heroImage
} = Astro.props;
---

<!doctype html>
<html lang="sv">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		
    <!-- SEO and Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Therese Järvheden" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="preconnect" href="https://uhdzswnawlqpsaajsjpo.supabase.co" crossorigin />
    <link rel="dns-prefetch" href="https://uhdzswnawlqpsaajsjpo.supabase.co" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter+Tight:wght@300;400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter+Tight:wght@300;400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter+Tight:wght@300;400;500;600&display=swap" />
    </noscript>
    
    {heroImage && (
      <link rel="preload" as="image" href={heroImage} fetchpriority="high" />
    )}

    <!-- Bot & Repeat Visitor Intro Bypass -->
    <script is:inline>
      (function() {
        try {
          var isBot = /bot|googlebot|crawler|spider|robot|crawling|lighthouse/i.test(navigator.userAgent);
          var introPlayed = sessionStorage.getItem('introPlayed');
          if (isBot || introPlayed) {
            document.documentElement.classList.add('skip-intro');
          }
        } catch (e) {}
      })();
    </script>
	</head>
	<body>
		<slot />
	</body>
</html>
