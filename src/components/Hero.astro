---
interface Props {
  heroImage?: string;
  heroLineSv?: string;
  heroLineEn?: string;
  heroRoleSv?: string;
  heroRoleEn?: string;
  heroBaseSv?: string;
  heroBaseEn?: string;
}

const {
  heroImage = "https://a6c2528650.clvaw-cdnwnd.com/a1d4e2b76c0723db65512f7305fc0d9c/200000000-339e8339ea/Thess1114_lowres.jpg?ph=a6c2528650",
  heroLineSv = '"En våldsam kärlek" — SVT dramadokumentär.',
  heroLineEn = '"En våldsam kärlek" — SVT documentary drama.',
  heroRoleSv = "Skådespelerska",
  heroRoleEn = "Actress",
  heroBaseSv = "Malmö · Stockholm",
  heroBaseEn = "Malmö · Stockholm",
} = Astro.props;
---

<section id="top" class="relative h-[100svh] w-full overflow-hidden bg-ink">
  <!-- Main Hero Image -->
  <div class="absolute inset-0">
    <img
      src={heroImage}
      alt="Therese Järvheden"
      class="h-full w-full object-cover object-[50%_25%] animate-hero-zoom"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-stage/40 via-stage/30 to-stage"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-stage/60 via-transparent to-stage/60"></div>
  </div>

  <!-- Curtain Reveal Panels (Pure CSS) -->
  <div class="absolute inset-x-0 top-0 z-30 h-1/2 bg-ink animate-slide-top"></div>
  <div class="absolute inset-x-0 bottom-0 z-30 h-1/2 bg-ink animate-slide-bottom"></div>

  <!-- Cinematic Title (LCP Element) - Replicates Framer layoutId morph -->
  <div class="fixed inset-0 z-40 pointer-events-none">
    <h1 class="absolute font-display text-bone tracking-[0.32em] uppercase flex items-center whitespace-nowrap animate-hero-logo pointer-events-auto">
      <a href="#top" class="flex items-center hover:opacity-85 transition-opacity duration-300" style="gap: inherit;">
        <span class="italic font-light">Therese</span>
        <span>Järvheden</span>
      </a>
    </h1>
  </div>

  <!-- Bottom Info Panel (CSS Animated, Localization via CSS) -->
  <div class="absolute inset-x-0 bottom-0 z-20 px-6 pb-10 md:px-12 md:pb-14 animate-slide-up-fade">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <!-- Swedish Version -->
      <div class="max-w-md lang-sv">
        <div class="text-[10px] uppercase tracking-[0.4em] text-ember">Akt I — Nu aktuell</div>
        <p class="mt-3 font-display text-xl md:text-2xl text-bone/90 italic leading-snug">
          {heroLineSv}
        </p>
      </div>
      <div class="flex items-center gap-6 text-[10px] uppercase tracking-[0.4em] text-bone/60 lang-sv">
        <span>{heroRoleSv}</span>
        <span class="h-px w-10 bg-bone/40"></span>
        <span>{heroBaseSv}</span>
      </div>

      <!-- English Version -->
      <div class="max-w-md lang-en">
        <div class="text-[10px] uppercase tracking-[0.4em] text-ember">Act I — Now Playing</div>
        <p class="mt-3 font-display text-xl md:text-2xl text-bone/90 italic leading-snug">
          {heroLineEn}
        </p>
      </div>
      <div class="flex items-center gap-6 text-[10px] uppercase tracking-[0.4em] text-bone/60 lang-en">
        <span>{heroRoleEn}</span>
        <span class="h-px w-10 bg-bone/40"></span>
        <span>{heroBaseEn}</span>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute left-1/2 bottom-3 z-20 -translate-x-1/2 text-[9px] uppercase tracking-[0.5em] text-bone/70 animate-scroll-text-fade">
    <span class="lang-sv">scrolla</span>
    <span class="lang-en">scroll</span>
  </div>
</section>

<script is:inline>
  // Dispatch an event precisely when the CSS animation reaches the Nav corner
  // to ensure perfect synchronization with React regardless of hydration delays.
  setTimeout(() => {
    window.dispatchEvent(new CustomEvent('hero-done'));
  }, 3300);
</script>

<style>
  /* CSS animations specifically optimized for the non-JS static Hero */
  @keyframes slideTop {
    0% { transform: translateY(0); }
    100% { transform: translateY(-100%); }
  }
  @keyframes slideBottom {
    0% { transform: translateY(0); }
    100% { transform: translateY(100%); }
  }
  @keyframes cinematicHandoffMobile {
    0%, 25.7% {
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-size: clamp(1.1rem, 4vw, 3.2rem); gap: 0.75rem; opacity: 0;
      animation-timing-function: ease-out;
    }
    42.8% {
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-size: clamp(1.1rem, 4vw, 3.2rem); gap: 0.75rem; opacity: 1;
    }
    48.6% {
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-size: clamp(1.1rem, 4vw, 3.2rem); gap: 0.75rem; opacity: 1;
      animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    }
    94.3%, 100% {
      top: 28px; left: 16px; transform: translate(0, 0);
      font-size: 14px; gap: 0.375rem; opacity: 1;
    }
  }

  @keyframes cinematicHandoffDesktop {
    0%, 25.7% {
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-size: clamp(1.1rem, 4vw, 3.2rem); gap: 0.75rem; opacity: 0;
      animation-timing-function: ease-out;
    }
    42.8% {
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-size: clamp(1.1rem, 4vw, 3.2rem); gap: 0.75rem; opacity: 1;
    }
    48.6% {
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-size: clamp(1.1rem, 4vw, 3.2rem); gap: 0.75rem; opacity: 1;
      animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    }
    94.3%, 100% {
      top: 20px; left: 40px; transform: translate(0, 0);
      font-size: 15px; gap: 0.375rem; opacity: 1;
    }
  }

  .animate-slide-top {
    animation: slideTop 1.4s cubic-bezier(0.76, 0, 0.24, 1) 0.2s both;
  }
  .animate-slide-bottom {
    animation: slideBottom 1.4s cubic-bezier(0.76, 0, 0.24, 1) 0.2s both;
  }
  .animate-hero-logo {
    animation: cinematicHandoffMobile 3.5s forwards;
  }
  @media (min-width: 1024px) {
    .animate-hero-logo {
      animation: cinematicHandoffDesktop 3.5s forwards;
    }
  }
  
  /* Bypass overrides for Bots / Repeat visitors */
  :global(html.skip-intro) .animate-slide-top {
    transform: translateY(-100%) !important;
    animation: none !important;
  }
  :global(html.skip-intro) .animate-slide-bottom {
    transform: translateY(100%) !important;
    animation: none !important;
  }
  :global(html.skip-intro) .animate-hero-logo,
  :global(html.logo-swapped) .animate-hero-logo {
    display: none !important;
  }
  :global(html.skip-intro) .animate-hero-zoom {
    transform: scale(1) !important;
    animation: none !important;
  }
  :global(html.skip-intro) .animate-slide-up-fade {
    opacity: 1 !important;
    transform: translateY(0) !important;
    animation: none !important;
  }
  :global(html.skip-intro) .animate-scroll-text-fade {
    opacity: 1 !important;
    animation: none !important;
  }

  /* Language toggle via CSS for the static hero */
  :global(html[lang="en"]) .lang-sv { display: none !important; }
  :global(html[lang="sv"]) .lang-en { display: none !important; }
  :global(html:not([lang])) .lang-en { display: none !important; }
</style>
