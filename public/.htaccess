# Apache Routing for Astro Clean URLs (Hostinger Fix)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories normally (e.g., _astro assets)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # If a directory index (e.g. /cv/index.html) exists, serve it
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.*[^/])/?$ $1/index.html [L]

  # If a flat HTML file (e.g. /cv.html) exists, serve it
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*[^/])/?$ $1.html [L]
</IfModule>

# Ensure index.html is recognized as the default page document
DirectoryIndex index.html

# Enable browser caching / Expires headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  # CSS, JavaScript (Astro builds fingerprinted files in _astro/)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"

  # Images and Media
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType audio/mpeg "access plus 1 year"

  # Fonts
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Custom cache control headers for static fingerprinted assets
<IfModule mod_headers.c>
  # 1 year caching for fingerprinted assets in _astro/ directory
  <FilesMatch "\.(js|css|webp|png|jpg|jpeg|gif|ico|woff|woff2|ttf|svg)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
</IfModule>

# Gzip compression configuration (if not enabled at server level)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>
